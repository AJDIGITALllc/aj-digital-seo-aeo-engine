# AJ Digital SEO/AEO Engine — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ─── Perplexity ───────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google Search Console ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GSC_SITE_URL=https://example.com

# ─── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── n8n (self-hosted) ────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── Optional: Ahrefs / SEMrush ───────────────────────────────────────────────
AHREFS_API_KEY=
SEMRUSH_API_KEY=
