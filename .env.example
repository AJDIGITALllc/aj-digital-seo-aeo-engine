# ─────────────────────────────────────────────────────────────────────────────
# AJ Digital SEO/AEO Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── AI Research — Perplexity ─────────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 4 (Perplexity Research)
PERPLEXITY_API_KEY=


# ─── AI Structuring — OpenAI ──────────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 9 (Build Briefs) + Node 4C (Revise)
OPENAI_API_KEY=


# ─── AI / Claude (Anthropic) ─────────────────────────────────────────────────
# Used for Claude-powered research, content generation, and audits
ANTHROPIC_API_KEY=


# ─── Google Search Console ────────────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 6 (GSC Search Analytics)
# OAuth2 credentials — obtain from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# The verified property URL in GSC (e.g. https://weareajdigital.com/)
GSC_SITE_URL=


# ─── Telegram (Approval Routing) ─────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 11, Workflow B
# Create bot via @BotFather. Get chat_id by messaging the bot and checking the API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 4A (Create Draft Record)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=


# ─── GitHub (Optional archive) ────────────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 5A (Commit Artifacts)
# Fine-grained PAT with contents:write on the target repo
GITHUB_TOKEN=
GITHUB_REPO=AJDIGITALllc/aj-digital-seo-aeo-engine


# ─── Cloudflare (Optional storage) ───────────────────────────────────────────
# Used in: workflows/n8n/seo-aeo-engine-workflow.md → Node 6A (Store Artifact)
# Skip until a Cloudflare Worker/KV/R2 endpoint is provisioned
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=


# ─── Analytics ────────────────────────────────────────────────────────────────
# Plausible — preferred privacy-first analytics
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=

# Google Analytics 4 (optional fallback)
GA4_MEASUREMENT_ID=


# ─── Automation / Make ────────────────────────────────────────────────────────
# Make (formerly Integromat) — webhook trigger for non-n8n automations
MAKE_WEBHOOK_URL=

# Slack — optional notifications for delivery pipeline events
SLACK_WEBHOOK_URL=


# ─── SEO Tools (Optional enrichment) ─────────────────────────────────────────
AHREFS_API_KEY=
SEMRUSH_API_KEY=


# ─── Project Config ───────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
