# AJ Digital SEO/AEO Engine — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ─── Client Identity (set per deployment) ────────────────────────────────────
# These values are injected into the n8n "Set Brand Config" node and code nodes.
# See clients/{slug}/client-profile.json for the full contract.
CLIENT_SLUG=your-client-slug
CLIENT_BRAND_NAME=Your Brand Name
CLIENT_SITE_URL=https://yourdomain.com
CLIENT_AUTHOR_NAME=Author Full Name
CLIENT_AUTHOR_TITLE=Author Professional Title
CLIENT_PRIMARY_CITY=Your Primary City
# Comma-separated list of all local markets (no spaces after commas)
CLIENT_LOCAL_CITIES=City1,City2,City3,near me
CLIENT_NICHE=describe your industry in one line
# Comma-separated seed topics for Perplexity weekly scan
CLIENT_SEED_TOPICS=topic one,topic two,topic three

# ─── Perplexity ───────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google Search Console ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GSC_SITE_URL=https://example.com

# ─── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── n8n (self-hosted) ────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── Optional: Ahrefs / SEMrush ───────────────────────────────────────────────
AHREFS_API_KEY=
SEMRUSH_API_KEY=
