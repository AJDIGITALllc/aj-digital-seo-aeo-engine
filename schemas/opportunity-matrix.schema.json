{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ajdigital.llc/schemas/opportunity-matrix.schema.json",
  "title": "OpportunityMatrix",
  "description": "SEO/AEO keyword and topic opportunity matrix output from the research pipeline.",
  "type": "object",
  "required": ["generated_at", "site_url", "opportunities"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this matrix was generated."
    },
    "site_url": {
      "type": "string",
      "format": "uri",
      "description": "The target site being analyzed."
    },
    "research_query": {
      "type": "string",
      "description": "The seed query or topic used to generate this matrix."
    },
    "opportunities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["keyword", "intent", "seo_score", "aeo_score", "priority"],
        "properties": {
          "keyword": {
            "type": "string",
            "description": "Target keyword or topic phrase."
          },
          "intent": {
            "type": "string",
            "enum": ["informational", "navigational", "commercial", "transactional"],
            "description": "Search intent classification."
          },
          "monthly_searches": {
            "type": ["integer", "null"],
            "description": "Estimated monthly search volume."
          },
          "difficulty": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100,
            "description": "Keyword difficulty score (0–100)."
          },
          "seo_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10,
            "description": "SEO opportunity score based on volume, difficulty, and relevance."
          },
          "aeo_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10,
            "description": "AEO opportunity score: likelihood of AI citation if content is created."
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Overall editorial priority."
          },
          "current_rank": {
            "type": ["integer", "null"],
            "description": "Current SERP rank for this keyword, if tracked."
          },
          "competitor_urls": {
            "type": "array",
            "items": { "type": "string", "format": "uri" },
            "description": "Top-ranking competitor URLs for this keyword."
          },
          "recommended_action": {
            "type": "string",
            "enum": ["create", "update", "optimize", "consolidate", "monitor"],
            "description": "Recommended content action."
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
